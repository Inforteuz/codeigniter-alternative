#!/usr/bin/env php
<?php

/**
 * Framework CLI Tool
 *
 * Provides artisan-like commands for development.
 */

require __DIR__ . '/../autoloader.php';
// if vendor/autoload exists, load it too
if (file_exists(__DIR__ . '/../vendor/autoload.php')) {
    require __DIR__ . '/../vendor/autoload.php';
}

use System\Core\Env;
use System\Database\Database;

// Load environment variables
Env::load();

class CLI
{
    protected $args;
    protected $command;

    public function __construct(array $args)
    {
        $this->args = $args;
        $this->command = $args[1] ?? 'help';
    }

    public function run()
    {
        switch ($this->command) {
            case 'make:controller':
                $this->makeController();
                break;
            case 'make:model':
                $this->makeModel();
                break;
            case 'make:migration':
                $this->makeMigration();
                break;
            case 'make:seeder':
                $this->makeSeeder();
                break;
            case 'db:seed':
                $this->dbSeed();
                break;
            case 'migrate':
                $this->migrate();
                break;
            case 'migrate:rollback':
                $this->migrateRollback();
                break;
            case 'migrate:refresh':
                $this->migrateRefresh();
                break;
            case 'serve':
                $this->serve();
                break;
            case 'help':
            default:
                $this->showHelp();
                break;
        }
    }

    protected function serve()
    {
        $host = $this->args[2] ?? '127.0.0.1';
        $port = $this->args[3] ?? '8080';
        $docroot = __DIR__ . '/../';
        
        echo "\033[32mCodeIgniter Alternative Dev Server started on http://{$host}:{$port}\033[0m\n";
        echo "Press Ctrl-C to quit.\n";
        
        passthru("php -S {$host}:{$port} -t \"{$docroot}\"");
    }

    protected function makeController()
    {
        $name = $this->args[2] ?? null;
        if (!$name) {
            echo "\033[31mError: Controller name required.\033[0m\n";
            return;
        }

        $name = ucfirst($name);
        if (strpos($name, 'Controller') === false) {
            $name .= 'Controller';
        }

        $content = <<<PHP
<?php

namespace App\Controllers;

use System\BaseController;

class {$name} extends BaseController
{
    public function index()
    {
        return \$this->view('welcome');
    }
}
PHP;

        $path = __DIR__ . "/../app/Controllers/{$name}.php";
        
        if (file_exists($path)) {
            echo "\033[31mError: Controller already exists.\033[0m\n";
            return;
        }

        file_put_contents($path, $content);
        echo "\033[32mController created successfully: {$path}\033[0m\n";
    }

    protected function makeModel()
    {
        $name = $this->args[2] ?? null;
        if (!$name) {
            echo "\033[31mError: Model name required.\033[0m\n";
            return;
        }

        $name = ucfirst($name);
        if (strpos($name, 'Model') === false) {
            $name .= 'Model';
        }

        $tableName = strtolower(str_replace('Model', '', $name)) . 's';

        $content = <<<PHP
<?php

namespace App\Models;

use System\BaseModel;

class {$name} extends BaseModel
{
    protected \$table = '{$tableName}';
    protected \$primaryKey = 'id';
    
    // Add validation rules
    protected \$validationRules = [];
}
PHP;

        $path = __DIR__ . "/../app/Models/{$name}.php";
        
        if (file_exists($path)) {
            echo "\033[31mError: Model already exists.\033[0m\n";
            return;
        }

        file_put_contents($path, $content);
        echo "\033[32mModel created successfully: {$path}\033[0m\n";
    }

    protected function makeMigration()
    {
        $name = $this->args[2] ?? null;
        if (!$name) {
            echo "\033[31mError: Migration name required.\033[0m\n";
            return;
        }

        $timestamp = date('Y_m_d_His');
        $className = str_replace(' ', '', ucwords(str_replace('_', ' ', $name)));
        $fileName = "{$timestamp}_{$name}.php";

        $content = <<<PHP
<?php

use App\Core\Database\Migration;
use App\Core\Database\Schema;
use App\Core\Database\Blueprint;

class {$className} extends Migration
{
    public function up()
    {
        Schema::create('{{table}}', function(Blueprint \$table) {
            \$table->id();
            \$table->timestamps();
        });
    }

    public function down()
    {
        Schema::dropIfExists('{{table}}');
    }
}
PHP;

        $dir = __DIR__ . "/../database/migrations";
        if (!is_dir($dir)) {
            mkdir($dir, 0777, true);
        }

        $path = "{$dir}/{$fileName}";
        file_put_contents($path, $content);
        
        echo "\033[32mMigration created successfully: {$path}\033[0m\n";
    }

    protected function makeSeeder()
    {
        $name = $this->args[2] ?? null;
        if (!$name) {
            echo "\033[31mError: Seeder name required.\033[0m\n";
            return;
        }

        $name = ucfirst($name);
        if (strpos($name, 'Seeder') === false) {
            $name .= 'Seeder';
        }

        $content = <<<PHP
<?php

namespace App\Database\Seeds;

use App\Core\Database\Seeder;
use System\Database\Database;

class {$name} extends Seeder
{
    public function run()
    {
        // \$this->db->exec("INSERT INTO table (col) VALUES ('val')");
    }
}
PHP;

        $dir = __DIR__ . "/../app/Database/Seeds";
        if (!is_dir($dir)) {
            mkdir($dir, 0777, true);
        }

        $path = "{$dir}/{$name}.php";
        
        if (file_exists($path)) {
            echo "\033[31mError: Seeder already exists.\033[0m\n";
            return;
        }

        file_put_contents($path, $content);
        echo "\033[32mSeeder created successfully: {$path}\033[0m\n";
    }

    protected function migrate()
    {
        echo "\033[33mRunning Migrations...\033[0m\n";
        $runner = new \App\Core\Database\MigrationRunner(__DIR__ . '/../database/migrations');
        $runner->migrate();
    }

    protected function migrateRollback()
    {
        echo "\033[33mRolling back...\033[0m\n";
        $runner = new \App\Core\Database\MigrationRunner(__DIR__ . '/../database/migrations');
        $runner->rollback();
    }

    protected function migrateRefresh()
    {
        echo "\033[33mRefreshing database...\033[0m\n";
        $runner = new \App\Core\Database\MigrationRunner(__DIR__ . '/../database/migrations');
        $runner->refresh();
    }

    protected function dbSeed()
    {
        $className = $this->args[2] ?? 'DatabaseSeeder';
        $fullClass = "\\App\\Database\\Seeds\\" . $className;

        if (!class_exists($fullClass)) {
            echo "\033[31mError: Seeder class {$fullClass} not found.\033[0m\n";
            return;
        }

        echo "\033[33mSeeding database with {$className}...\033[0m\n";
        $seeder = new $fullClass();
        $seeder->run();
        echo "\033[32mDatabase seeding completed successfully.\033[0m\n";
    }

    protected function showHelp()
    {
        echo "\033[32mFramework CLI Tool\033[0m\n\n";
        echo "Usage:\n";
        echo "  php bin/framework [command] [arguments]\n\n";
        echo "Available Commands:\n";
        echo "  \033[33mmake:controller\033[0m <Name>      Create a new controller\n";
        echo "  \033[33mmake:model\033[0m <Name>           Create a new model\n";
        echo "  \033[33mmake:migration\033[0m <name>       Create a new migration file\n";
        echo "  \033[33mmake:seeder\033[0m <Name>          Create a new database seeder\n";
        echo "  \033[33mdb:seed\033[0m [class]             Run the database seeds (default: DatabaseSeeder)\n";
        echo "  \033[33mmigrate\033[0m                     Run pending database migrations\n";
        echo "  \033[33mmigrate:rollback\033[0m            Rollback the last migration operation\n";
        echo "  \033[33mmigrate:refresh\033[0m             Rollback all migrations and run them again\n";
        echo "  \033[33mserve\033[0m [host] [port]         Start the development server\n";
    }
}

$cli = new CLI($argv);
$cli->run();
